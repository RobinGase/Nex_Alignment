# Global switch for optional external workflows/tool-calls.
NAP_OPTIONAL_WORKFLOWS_ENABLED=false

# Strict mode: if true, warning/failure in enabled optional workflows returns exit code 2.
NAP_OPTIONAL_WORKFLOWS_STRICT=false

# Optional Notion workflow:
# - Leave blank to auto-detect based on NOTION_* secrets.
# - Set true/false to force explicit behavior.
NAP_WORKFLOW_NOTION_ENABLED=

# Required for Notion workflow.
NOTION_API_KEY=

# Set at least one target.
NOTION_DATABASE_ID=
NOTION_PARENT_PAGE_ID=

# Optional heartbeat page creation (requires NOTION_DATABASE_ID).
NAP_WORKFLOW_NOTION_CREATE_HEARTBEAT=false
NAP_WORKFLOW_NOTION_HEARTBEAT_TITLE=NAP Optional Workflow Heartbeat
